# Base URL del API en el navegador. Déjalo sin definir para usar la misma
# origen que la página (recomendado con Nginx o al abrir por IP pública).
#
# Solo necesitas VITE_API_URL si el front y el API están en hosts/puertos distintos
# y no hay proxy (poco habitual).
# VITE_API_URL=http://localhost:8000
